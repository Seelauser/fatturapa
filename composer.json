{
  "name": "alpsplanner/fatturapa",
  "description": "Framework-free PHP library to build Italian FatturaPA (SdI) e-invoice XML and reserve sequential invoice numbers, with an optional HTTP microservice.",
  "type": "library",
  "keywords": ["fatturapa", "sdi", "e-invoice", "italy", "fattura elettronica", "agenzia entrate"],
  "license": "MIT",
  "authors": [
    { "name": "AlpsPlanner", "homepage": "https://alpsplanner.com" }
  ],
  "require": {
    "php": "^8.2",
    "ext-dom": "*",
    "ext-libxml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "guzzlehttp/guzzle": "^7.9",
    "vlucas/phpdotenv": "^5.6"
  },
  "suggest": {
    "slim/slim": "Run the bundled HTTP microservice (public/index.php)",
    "guzzlehttp/guzzle": "Required by the Openapi.com SdI transport adapter"
  },
  "autoload": {
    "psr-4": {
      "AlpsFatturapa\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AlpsFatturapa\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
