{
  "name": "alpsplanner/fatturapa-svc",
  "description": "FatturaPA / SdI microservice — standalone HTTP wrapper around XmlBuilder + NumeratoreService",
  "type": "project",
  "require": {
    "php": "^8.3",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "monolog/monolog": "^3.7",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  },
  "autoload": {
    "psr-4": {
      "AlpsFatturapa\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AlpsFatturapa\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true
  }
}
